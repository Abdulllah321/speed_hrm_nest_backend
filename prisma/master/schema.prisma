  leaveType      LeaveType    @relation(fields: [leaveTypeId], references: [id], onDelete: Cascade)
  leavesPolicy   LeavesPolicy @relation(fields: [leavesPolicyId], references: [id], onDelete: Cascade)

  @@unique([leavesPolicyId, leaveTypeId])
