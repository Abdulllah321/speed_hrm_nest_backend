}

model City {
  id          String     @id @default(uuid())
  name        String
  countryId   String
  stateId     String
  status      String     @default("active")
  createdById String?
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt
  country     Country    @relation(fields: [countryId], references: [id], onDelete: Cascade)
