// ==================== POS & MODULE ==============================

model Location {
  id                 String   @id @default(uuid())
  name               String   @unique
  code               String   @unique @default(cuid()) // Unique code for identifying location (e.g. NYC-01)
  phone              String?
  geoFenceEnabled    Boolean  @default(false)
  geoFenceRadius     Int      @default(100) // In meters
  ipWhitelist        String? // Comma separated list of allowed IPs
  ipWhitelistEnabled Boolean  @default(false)
  address            String?
  latitude           Decimal? @db.Decimal(10, 8) // For geolocation-based nearest location detection
  longitude          Decimal? @db.Decimal(11, 8) // For geolocation-based nearest location detection
  cityId             String? // Refers to City in Master DB
  companyId          String? // Refers to Company in Master DB
  status             String   @default("active")
  createdById        String? // Refers to User in Master DB
  createdAt          DateTime @default(now())
  updatedAt          DateTime @updatedAt
  pos                Pos[]

  employees             Employee[]
  transferHistoriesPrev EmployeeTransferHistory[] @relation("TransferPrevLoc")
  transferHistoriesNew  EmployeeTransferHistory[] @relation("TransferNewLoc")

  // POS config reverse relations
  promoCampaignLocations    PromoCampaignLocation[]
  couponCodeLocations       CouponCodeLocation[]
  allianceDiscountLocations AllianceDiscountLocation[]
}

model Pos {
  id           String   @id @default(uuid())
  posId        String // 3-character unique ID for this location
  terminalCode String   @unique // Unique code for cloud-based terminal identification (e.g., MAIN-01)
  name         String
  locationId   String
  location     Location @relation(fields: [locationId], references: [id], onDelete: Cascade)
  companyId    String? // Direct link for easier querying. Refers to Company 
  terminalPin  String? // Hashed pin for specialized POS login
  status       String   @default("active")
  createdById  String? // Refers to User in Master DB
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  sessions PosSession[]

  @@unique([locationId, posId])
}

model PosSession {
  id       String    @id @default(uuid())
  posId    String
  pos      Pos       @relation(fields: [posId], references: [id], onDelete: Cascade)
  userId   String? // The user who opened the session. Refers to User in Master DB
  openedAt DateTime  @default(now())
  closedAt DateTime?
  status   String    @default("open") // open, closed
  token    String? // Associated JWT for this session

  // ── Cash Drawer Fields ──────────────────────────────────────────
  openingFloat Decimal  @default(0) @db.Decimal(15, 2)
  openingNote  String?
  expectedCash Decimal? @db.Decimal(15, 2)
  actualCash   Decimal? @db.Decimal(15, 2)
  difference   Decimal? @db.Decimal(15, 2)
  closingNote  String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([posId])
  @@index([status])
}
