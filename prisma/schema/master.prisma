model Location {
  id                        String                     @id @default(uuid())
  name                      String                     @unique
  code                      String                     @unique @default(cuid())
  phone                     String?
  geoFenceEnabled           Boolean                    @default(false)
  geoFenceRadius            Int                        @default(100)
  ipWhitelist               String?
  ipWhitelistEnabled        Boolean                    @default(false)
  address                   String?
  latitude                  Decimal?                   @db.Decimal(10, 8)
  longitude                 Decimal?                   @db.Decimal(11, 8)
  cityId                    String?
  companyId                 String?
  status                    String                     @default("active")
  createdById               String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  // ── FBR POS credentials (per-location) ──────────────────────────────
  fbrBposId                 String?                    @map("fbr_bpos_id")
  fbrBearerToken            String?                    @map("fbr_bearer_token") @db.Text
  fbrNtn                    String?                    @map("fbr_ntn")
  fbrSellerName             String?                    @map("fbr_seller_name")
  fbrEnabled                Boolean                    @default(false) @map("fbr_enabled")
  employees                 Employee[]
  transferHistoriesNew      EmployeeTransferHistory[]  @relation("TransferNewLoc")
  transferHistoriesPrev     EmployeeTransferHistory[]  @relation("TransferPrevLoc")
  pos                       Pos[]
  allianceDiscountLocations AllianceDiscountLocation[]
  couponCodeLocations       CouponCodeLocation[]
  promoCampaignLocations    PromoCampaignLocation[]
  fromTransferRequests      TransferRequest[]          @relation("TransferRequest_fromLocationIdToWarehouseLocation")
  toTransferRequests        TransferRequest[]          @relation("TransferRequest_toLocationIdToWarehouseLocation")
  fromStockMovements        StockMovement[]            @relation("StockMovement_fromLocation")
  toStockMovements          StockMovement[]            @relation("StockMovement_toLocation")
  inventoryItems            InventoryItem[]

  voucherLocations VoucherLocation[]
}

model Pos {
  id           String       @id @default(uuid())
  posId        String
  terminalCode String       @unique
  name         String
  locationId   String
  companyId    String?
  terminalPin  String?
  status       String       @default("active")
  createdById  String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt
  location     Location     @relation(fields: [locationId], references: [id], onDelete: Cascade)
  sessions     PosSession[]

  @@unique([locationId, posId])
}

model PosSession {
  id           String    @id @default(uuid())
  posId        String
  userId       String?
  openedAt     DateTime  @default(now())
  closedAt     DateTime?
  status       String    @default("open")
  token        String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  actualCash   Decimal?  @db.Decimal(15, 2)
  closingNote  String?
  difference   Decimal?  @db.Decimal(15, 2)
  expectedCash Decimal?  @db.Decimal(15, 2)
  openingFloat Decimal   @default(0) @db.Decimal(15, 2)
  openingNote  String?
  pos          Pos       @relation(fields: [posId], references: [id], onDelete: Cascade)

  @@index([posId])
  @@index([status])
}
