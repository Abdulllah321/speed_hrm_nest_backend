model ChartOfAccount {
  id                    String                 @id @default(uuid())
  code                  String
  name                  String
  type                  AccountType
  isGroup               Boolean                @default(false)
  parentId              String?
  balance               Decimal                @default(0.0) @db.Decimal(15, 2)
  isActive              Boolean                @default(true)
  createdById           String?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt
  parent                ChartOfAccount?        @relation("ChartOfAccountHierarchy", fields: [parentId], references: [id])
  children              ChartOfAccount[]       @relation("ChartOfAccountHierarchy")
  journalVoucherDetails JournalVoucherDetail[]
  paymentVoucherCredit  PaymentVoucher[]       @relation("CreditAccountRelation")
  paymentVoucherDebit   PaymentVoucherDetail[]
  receiptVoucherDebit   ReceiptVoucher[]       @relation("DebitAccountRelation")
  receiptVoucherCredit  ReceiptVoucherDetail[]
  landedCostChargeTypes LandedCostChargeType[]
  suppliers             Supplier[]             @relation("ChartOfAccountToSupplier")
  transactions          AccountTransaction[]
  financeConfigs        FinanceAccountConfig[]

  // Sales Relations

  @@index([parentId])
  @@index([type])
}

enum AccountType {
  ASSET
  LIABILITY
  EQUITY
  INCOME
  EXPENSE
}
