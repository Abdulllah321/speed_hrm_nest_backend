model ReceiptVoucher {
  id             String                    @id @default(uuid())
  type           String
  rvNo           String                    @unique
  rvDate         DateTime
  refBillNo      String?
  billDate       DateTime?
  chequeNo       String?
  chequeDate     DateTime?
  debitAccountId String
  debitAmount    Decimal                   @default(0.0) @db.Decimal(15, 2)
  customerId     String?
  description    String
  status         String                    @default("approved")
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  createdBy      String?
  debitAccount   ChartOfAccount            @relation("DebitAccountRelation", fields: [debitAccountId], references: [id])
  details        ReceiptVoucherDetail[]
  invoices       ReceiptVoucherToInvoice[]
}

model ReceiptVoucherToInvoice {
  id               String          @id @default(uuid())
  receiptVoucherId String          @map("receipt_voucher_id")
  salesInvoiceId   String          @map("sales_invoice_id")
  receivedAmount   Decimal         @map("received_amount") @db.Decimal(15, 2)
  receiptVoucher   ReceiptVoucher  @relation(fields: [receiptVoucherId], references: [id], onDelete: Cascade)

  @@index([receiptVoucherId])
  @@index([salesInvoiceId])
  @@map("receipt_voucher_to_invoices")
}

model ReceiptVoucherDetail {
  id               String         @id @default(uuid())
  receiptVoucherId String
  accountId        String
  credit           Decimal        @default(0.0) @db.Decimal(15, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  account          ChartOfAccount @relation(fields: [accountId], references: [id])
  receiptVoucher   ReceiptVoucher @relation(fields: [receiptVoucherId], references: [id], onDelete: Cascade)

  @@index([receiptVoucherId])
  @@index([accountId])
}
