model ReceiptVoucher {
  id             String                    @id @default(uuid())
  type           String
  rvNo           String                    @unique
  rvDate         DateTime
  refBillNo      String?
  billDate       DateTime?
  chequeNo       String?
  chequeDate     DateTime?
  debitAccountId String
  debitAmount    Decimal                   @default(0.0) @db.Decimal(15, 2)
  customerId     String?
  description    String
  status         String                    @default("approved")
  isAdvance       Boolean                   @default(false)
  advanceApplied  Decimal                   @default(0.0) @db.Decimal(15, 2)
  isTaxApplicable Boolean                   @default(false)
  createdAt      DateTime                  @default(now())
  updatedAt      DateTime                  @updatedAt
  createdBy      String?
  debitAccount   ChartOfAccount            @relation("DebitAccountRelation", fields: [debitAccountId], references: [id])
  customer       Customer?                 @relation(fields: [customerId], references: [id])
  details        ReceiptVoucherDetail[]
  invoices       ReceiptVoucherToInvoice[]
}

model ReceiptVoucherToInvoice {
  id               String         @id @default(uuid())
  receiptVoucherId String         @map("receipt_voucher_id")
  salesInvoiceId   String         @map("sales_invoice_id")
  receivedAmount   Decimal        @map("received_amount") @db.Decimal(15, 2)
  receiptVoucher   ReceiptVoucher @relation(fields: [receiptVoucherId], references: [id], onDelete: Cascade)

  @@index([receiptVoucherId])
  @@index([salesInvoiceId])
  @@map("receipt_voucher_to_invoices")
}

model ReceiptVoucherDetail {
  id               String          @id @default(uuid())
  receiptVoucherId String
  accountId        String
  tagAccountId     String?         // Optional sub-ledger tag (child chart-of-account)
  debit            Decimal         @default(0.0) @db.Decimal(15, 2)
  credit           Decimal         @default(0.0) @db.Decimal(15, 2)
  narration        String?
  refBillNo        String?
  isTaxApplicable  Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  account          ChartOfAccount  @relation("RVDetailAccount", fields: [accountId], references: [id])
  tagAccount       ChartOfAccount? @relation("RVDetailTagAccount", fields: [tagAccountId], references: [id])
  receiptVoucher   ReceiptVoucher  @relation(fields: [receiptVoucherId], references: [id], onDelete: Cascade)

  @@index([receiptVoucherId])
  @@index([accountId])
  @@index([tagAccountId])
}
