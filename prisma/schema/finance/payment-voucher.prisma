model PaymentVoucher {
  id              String                 @id @default(uuid())
  type            String
  pvNo            String                 @unique
  pvDate          DateTime
  refBillNo       String?
  billDate        DateTime?
  chequeNo        String?
  chequeDate      DateTime?
  creditAccountId String
  supplierId      String?
  creditAmount    Decimal                @default(0.0) @db.Decimal(15, 2)
  isAdvance       Boolean                @default(false)
  advanceApplied  Decimal                @default(0.0) @db.Decimal(15, 2)
  isTaxApplicable Boolean                @default(false)
  description     String
  status          String                 @default("approved")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdBy       String?
  creditAccount   ChartOfAccount         @relation("CreditAccountRelation", fields: [creditAccountId], references: [id])
  supplier        Supplier?              @relation(fields: [supplierId], references: [id])
  details         PaymentVoucherDetail[]
  invoices        PaymentVoucherToInvoice[]
  // Advances applied FROM this voucher (when this is an advance PV being consumed)
  advanceUsages   AdvanceApplication[]   @relation("SourceAdvance")
}

model PaymentVoucherToInvoice {
  id                String          @id @default(uuid())
  paymentVoucherId  String          @map("payment_voucher_id")
  purchaseInvoiceId String          @map("purchase_invoice_id")
  paidAmount        Decimal         @map("paid_amount") @db.Decimal(15, 2)
  paymentVoucher    PaymentVoucher  @relation(fields: [paymentVoucherId], references: [id], onDelete: Cascade)
  purchaseInvoice   PurchaseInvoice @relation(fields: [purchaseInvoiceId], references: [id], onDelete: Cascade)

  @@index([paymentVoucherId])
  @@index([purchaseInvoiceId])
  @@map("payment_voucher_to_invoices")
}

model PaymentVoucherDetail {
  id               String         @id @default(uuid())
  paymentVoucherId String
  accountId        String
  debit            Decimal        @default(0.0) @db.Decimal(15, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  account          ChartOfAccount @relation(fields: [accountId], references: [id])
  paymentVoucher   PaymentVoucher @relation(fields: [paymentVoucherId], references: [id], onDelete: Cascade)

  @@index([paymentVoucherId])
  @@index([accountId])
}

/// Tracks how much of an advance PV has been applied to settle invoices
model AdvanceApplication {
  id                    String         @id @default(uuid())
  sourceAdvanceId       String         @map("source_advance_id")
  appliedInVoucherId    String         @map("applied_in_voucher_id")
  appliedAmount         Decimal        @map("applied_amount") @db.Decimal(15, 2)
  createdAt             DateTime       @default(now())
  sourceAdvance         PaymentVoucher @relation("SourceAdvance", fields: [sourceAdvanceId], references: [id], onDelete: Cascade)

  @@index([sourceAdvanceId])
  @@index([appliedInVoucherId])
  @@map("advance_applications")
}
