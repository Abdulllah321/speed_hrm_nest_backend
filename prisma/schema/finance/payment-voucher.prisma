model PaymentVoucher {
  id              String                 @id @default(uuid())
  type            String
  pvNo            String                 @unique
  pvDate          DateTime
  refBillNo       String?
  billDate        DateTime?
  chequeNo        String?
  chequeDate      DateTime?
  creditAccountId String
  supplierId      String?
  creditAmount    Decimal                @default(0.0) @db.Decimal(15, 2)
  isAdvance       Boolean                @default(false)
  isTaxApplicable Boolean                @default(false)
  description     String
  status          String                 @default("pending")
  createdAt       DateTime               @default(now())
  updatedAt       DateTime               @updatedAt
  createdBy       String?
  creditAccount   ChartOfAccount         @relation("CreditAccountRelation", fields: [creditAccountId], references: [id])
  supplier        Supplier?              @relation(fields: [supplierId], references: [id])
  details         PaymentVoucherDetail[]
}

model PaymentVoucherDetail {
  id               String         @id @default(uuid())
  paymentVoucherId String
  accountId        String
  debit            Decimal        @default(0.0) @db.Decimal(15, 2)
  createdAt        DateTime       @default(now())
  updatedAt        DateTime       @updatedAt
  account          ChartOfAccount @relation(fields: [accountId], references: [id])
  paymentVoucher   PaymentVoucher @relation(fields: [paymentVoucherId], references: [id], onDelete: Cascade)

  @@index([paymentVoucherId])
  @@index([accountId])
}
