model Supplier {
  id               String                      @id @default(uuid())
  code             String                      @unique
  brand            String?
  name             String
  nature           String?
  type             SupplierType?               @default(LOCAL)
  address          String?
  city             String?
  country          String?                     @default("Pakistan")
  contactNo        String?
  email            String?
  website          String?
  cnicNo           String?
  ntnNo            String?
  strnNo           String?
  srbNo            String?
  praNo            String?
  ictNo            String?
  paymentTerms     String?
  creditLimit      Decimal?                    @db.Decimal(15, 2)
  openingBalance   Decimal                     @default(0.0) @db.Decimal(15, 2)
  isActive         Boolean                     @default(true)
  createdById      String?
  createdAt        DateTime                    @default(now())
  updatedAt        DateTime                    @updatedAt
  paymentVouchers  PaymentVoucher[]
  landedCosts      LandedCost[]
  purchaseOrders   PurchaseOrder[]
  purchaseInvoices PurchaseInvoice[]
  purchaseReturns  PurchaseReturn[]
  rfqVendors       RequestForQuotationVendor[]
  vendorQuotations VendorQuotation[]
  chartOfAccounts  ChartOfAccount[]            @relation("ChartOfAccountToSupplier")
  debitNotes      DebitNote[]


  @@index([nature])
  @@index([type])
}

enum SupplierNature {
  GOODS
  SERVICES
}

enum SupplierType {
  LOCAL
  INTERNATIONAL
}
