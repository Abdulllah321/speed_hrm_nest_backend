model JournalVoucher {
  id          String                 @id @default(uuid())
  jvNo        String                 @unique
  jvDate      DateTime
  description String
  status      String                 @default("pending")
  createdAt   DateTime               @default(now())
  updatedAt   DateTime               @updatedAt
  details     JournalVoucherDetail[]
}

model JournalVoucherDetail {
  id               String          @id @default(uuid())
  journalVoucherId String
  accountId        String
  tagAccountId     String?         // Optional sub-ledger tag (child chart-of-account)
  debit            Decimal         @default(0.0) @db.Decimal(15, 2)
  credit           Decimal         @default(0.0) @db.Decimal(15, 2)
  narration        String?
  refBillNo        String?
  isTaxApplicable  Boolean         @default(false)
  createdAt        DateTime        @default(now())
  updatedAt        DateTime        @updatedAt
  account          ChartOfAccount  @relation("JVDetailAccount", fields: [accountId], references: [id])
  tagAccount       ChartOfAccount? @relation("JVDetailTagAccount", fields: [tagAccountId], references: [id])
  journalVoucher   JournalVoucher  @relation(fields: [journalVoucherId], references: [id], onDelete: Cascade)

  @@index([journalVoucherId])
  @@index([accountId])
  @@index([tagAccountId])
}
