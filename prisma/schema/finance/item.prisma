model Item {
  id                 String        @id @default(uuid())
  itemId             String        @unique
  sku                String        
  barCode            String?
  hsCode             String?
  description        String?
  imageUrl           String?
  status             String        @default("active")
  isActive           Boolean       @default(true)
  unitPrice          Float         @default(0)
  taxRate1           Float?        @default(0)
  taxRate2           Float?        @default(0)
  discountRate       Float?        @default(0)
  discountAmount     Float?        @default(0)
  discountStartDate  DateTime?
  discountEndDate    DateTime?
  fob                Float         @default(0)
  unitCost           Float         @default(0) @map("unit_cost")
  case               String?
  band               String?
  movementType       String?
  heelHeight         String?
  width              String?
  brandId            String?
  divisionId         String?
  genderId           String?
  sizeId             String?
  silhouetteId       String?
  channelClassId     String?
  colorId            String?
  categoryId         String?
  subCategoryId      String?
  itemClassId        String?
  itemSubclassId     String?
  seasonId           String?
  segmentId          String?
  createdAt          DateTime      @default(now())
  updatedAt          DateTime      @updatedAt
  stockLedgerEntries StockLedger[]
}
