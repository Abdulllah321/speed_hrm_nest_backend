model PurchaseRequisition {
  id          String                    @id @default(uuid())
  prNumber    String                    @unique @map("pr_number")
  department  String?
  type        String?                   @default("local")
  requestDate DateTime                  @default(now()) @map("request_date")
  status      String                    @default("DRAFT")
  notes       String?
  createdAt   DateTime                  @default(now()) @map("created_at")
  updatedAt   DateTime                  @updatedAt @map("updated_at")
  items       PurchaseRequisitionItem[]
  rfqs        RequestForQuotation[]
  purchaseOrders PurchaseOrder[]

  @@map("purchase_requisitions")
}

model PurchaseRequisitionItem {
  id                    String              @id @default(uuid())
  purchaseRequisitionId String              @map("purchase_requisition_id")
  itemId                String              @map("item_id")
  requiredQty           Decimal             @map("required_qty") @db.Decimal(15, 4)
  createdAt             DateTime            @default(now()) @map("created_at")
  updatedAt             DateTime            @updatedAt @map("updated_at")
  purchaseRequisition   PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id], onDelete: Cascade)

  @@map("purchase_requisition_items")
}
