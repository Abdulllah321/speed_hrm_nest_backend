model RequestForQuotation {
    id                    String              @id @default(uuid())
    rfqNumber             String              @unique @map("rfq_number")
    purchaseRequisitionId String              @map("purchase_requisition_id")
    purchaseRequisition   PurchaseRequisition @relation(fields: [purchaseRequisitionId], references: [id])

    rfqDate DateTime @default(now()) @map("rfq_date")
    status  String   @default("DRAFT") // DRAFT, SENT, CLOSED
    notes   String?

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    vendors          RequestForQuotationVendor[]
    vendorQuotations VendorQuotation[]
    purchaseOrders   PurchaseOrder[]

    @@map("rfqs")
}

model RequestForQuotationVendor {
    id    String              @id @default(uuid())
    rfqId String              @map("rfq_id")
    rfq   RequestForQuotation @relation(fields: [rfqId], references: [id], onDelete: Cascade)

    vendorId String   @map("vendor_id")
    vendor   Supplier @relation(fields: [vendorId], references: [id])

    sentAt         DateTime? @map("sent_at")
    responseStatus String    @default("PENDING") @map("response_status") // PENDING, RESPONDED, DECLINED

    createdAt DateTime @default(now()) @map("created_at")
    updatedAt DateTime @updatedAt @map("updated_at")

    @@unique([rfqId, vendorId])
    @@map("rfq_vendors")
}
