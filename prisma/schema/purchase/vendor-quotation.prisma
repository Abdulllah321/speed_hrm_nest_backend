model VendorQuotation {
  id             String                @id @default(uuid())
  rfqId          String
  vendorId       String
  quotationDate  DateTime              @default(now())
  status         String                @default("DRAFT")
  subtotal       Decimal               @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal               @default(0) @db.Decimal(15, 2)
  discountAmount Decimal               @default(0) @db.Decimal(15, 2)
  totalAmount    Decimal               @default(0) @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime              @default(now())
  updatedAt      DateTime              @updatedAt
  expiryDate     DateTime?
  purchaseOrders PurchaseOrder[]
  items          VendorQuotationItem[]
  rfq            RequestForQuotation   @relation(fields: [rfqId], references: [id])
  vendor         Supplier              @relation(fields: [vendorId], references: [id])

  @@unique([rfqId, vendorId])
  @@map("vendor_quotations")
}

model VendorQuotationItem {
  id                String          @id @default(uuid())
  vendorQuotationId String
  itemId            String
  description       String?
  quotedQty         Decimal         @db.Decimal(15, 4)
  unitPrice         Decimal         @db.Decimal(15, 2)
  taxPercent        Decimal         @default(0) @db.Decimal(5, 2)
  discountPercent   Decimal         @default(0) @db.Decimal(5, 2)
  lineTotal         Decimal         @db.Decimal(15, 2)
  createdAt         DateTime        @default(now())
  updatedAt         DateTime        @updatedAt
  fob               Decimal         @default(0) @db.Decimal(15, 2)
  unitCost          Decimal         @default(0) @db.Decimal(15, 2)
  vendorQuotation   VendorQuotation @relation(fields: [vendorQuotationId], references: [id], onDelete: Cascade)
  item              Item            @relation(fields: [itemId], references: [id])

  @@map("vendor_quotation_items")
}
