model VendorQuotation {
  id             String                @id @default(uuid())
  rfqId          String                @map("rfq_id")
  vendorId       String                @map("vendor_id")
  quotationDate  DateTime              @default(now()) @map("quotation_date")
  status         String                @default("DRAFT")
  subtotal       Decimal               @default(0) @db.Decimal(15, 2)
  taxAmount      Decimal               @default(0) @map("tax_amount") @db.Decimal(15, 2)
  discountAmount Decimal               @default(0) @map("discount_amount") @db.Decimal(15, 2)
  totalAmount    Decimal               @default(0) @map("total_amount") @db.Decimal(15, 2)
  notes          String?
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  purchaseOrders PurchaseOrder[]
  items          VendorQuotationItem[]
  rfq            RequestForQuotation   @relation(fields: [rfqId], references: [id])
  vendor         Supplier              @relation(fields: [vendorId], references: [id])

  @@unique([rfqId, vendorId])
  @@map("vendor_quotations")
}

model VendorQuotationItem {
  id                String          @id @default(uuid())
  vendorQuotationId String          @map("vendor_quotation_id")
  itemId            String          @map("item_id")
  description       String?
  quotedQty         Decimal         @map("quoted_qty") @db.Decimal(15, 4)
  unitPrice         Decimal         @map("unit_price") @db.Decimal(15, 2)
  taxPercent        Decimal         @default(0) @map("tax_percent") @db.Decimal(5, 2)
  discountPercent   Decimal         @default(0) @map("discount_percent") @db.Decimal(5, 2)
  lineTotal         Decimal         @map("line_total") @db.Decimal(15, 2)
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  vendorQuotation   VendorQuotation @relation(fields: [vendorQuotationId], references: [id], onDelete: Cascade)

  @@map("vendor_quotation_items")
}
