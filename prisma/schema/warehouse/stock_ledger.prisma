enum MovementType {
    INBOUND
    OUTBOUND
    TRANSFER
    ADJUSTMENT
    OPENING_BALANCE
}

model StockLedger {
    id          String @id @default(uuid())
    itemId      String @map("item_id")
    warehouseId String @map("warehouse_id")

    item      Item      @relation(fields: [itemId], references: [id])
    warehouse Warehouse @relation(fields: [warehouseId], references: [id])

    qty Decimal @db.Decimal(15, 4) // Positive for IN, Negative for OUT

    movementType MovementType @map("movement_type")

    // Optional location for bin-level tracking
    locationId String? @map("location_id")

    // Reference to source document
    referenceType String @map("reference_type") // e.g. "GRN", "STOCK_ADJUSTMENT"
    referenceId   String @map("reference_id") // ID of the document

    createdAt DateTime @default(now()) @map("created_at")

    @@index([itemId])
    @@index([warehouseId])
    @@index([referenceId])
    @@index([movementType])
    @@map("stock_ledgers")
}
