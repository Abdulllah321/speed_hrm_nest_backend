model Warehouse {
  id                   String              @id @default(uuid())
  code                 String              @unique
  name                 String
  address              String?
  type                 String              @default("GENERAL")
  description          String?
  isActive             Boolean             @default(true)
  managerId            String?
  companyId            String?
  createdAt            DateTime            @default(now())
  updatedAt            DateTime            @updatedAt
  createdById          String?
  updatedById          String?
  WarehouseLocation    WarehouseLocation[]
  goodsReceiptNotes    GoodsReceiptNote[]
  stockLedgerEntries   StockLedger[]
  inventoryItems       InventoryItem[]
  purchaseReturns      PurchaseReturn[]
  fromTransferRequests TransferRequest[]   @relation("TransferRequest_fromWarehouse")
  toTransferRequests   TransferRequest[]   @relation("TransferRequest_toWarehouse")

  // Sales Relations
  erpSalesOrders   ERPSalesOrder[]
  deliveryChallans DeliveryChallan[]
  erpSalesInvoices ERPSalesInvoice[]
  purchaseInvoices PurchaseInvoice[]

  @@index([companyId])
  @@index([type])
}

model Location {
  id                        String                     @id @default(uuid())
  name                      String                     @unique
  code                      String                     @unique @default(cuid())
  phone                     String?
  warehouseId               String?                    @map("warehouse_id")
  geoFenceEnabled           Boolean                    @default(false)
  geoFenceRadius            Int                        @default(100)
  ipWhitelist               String?
  ipWhitelistEnabled        Boolean                    @default(false)
  address                   String?
  latitude                  Decimal?                   @db.Decimal(10, 8)
  longitude                 Decimal?                   @db.Decimal(11, 8)
  cityId                    String?
  companyId                 String?
  status                    String                     @default("active")
  createdById               String?
  createdAt                 DateTime                   @default(now())
  updatedAt                 DateTime                   @updatedAt
  // ── FBR POS credentials (per-location) ──────────────────────────────
  fbrBposId                 String?                    @map("fbr_bpos_id")
  fbrBearerToken            String?                    @map("fbr_bearer_token") @db.Text
  fbrNtn                    String?                    @map("fbr_ntn")
  fbrSellerName             String?                    @map("fbr_seller_name")
  fbrEnabled                Boolean                    @default(false) @map("fbr_enabled")
  employees                 Employee[]
  transferHistoriesNew      EmployeeTransferHistory[]  @relation("TransferNewLoc")
  transferHistoriesPrev     EmployeeTransferHistory[]  @relation("TransferPrevLoc")
  pos                       Pos[]
  allianceDiscountLocations AllianceDiscountLocation[]
  couponCodeLocations       CouponCodeLocation[]
  promoCampaignLocations    PromoCampaignLocation[]
  fromTransferRequests      TransferRequest[]          @relation("TransferRequest_fromLocationIdToWarehouseLocation")
  toTransferRequests        TransferRequest[]          @relation("TransferRequest_toLocationIdToWarehouseLocation")
  fromStockMovements        StockMovement[]            @relation("StockMovement_fromLocation")
  toStockMovements          StockMovement[]            @relation("StockMovement_toLocation")
  inventoryItems            InventoryItem[]

  voucherLocations          VoucherLocation[]
  discountCampaignLocations DiscountCampaignLocation[]

  @@index([warehouseId])
}
