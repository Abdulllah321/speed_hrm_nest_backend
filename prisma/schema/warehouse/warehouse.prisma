model Warehouse {
  id                 String              @id @default(uuid())
  code               String              @unique
  name               String
  address            String?
  type               String              @default("GENERAL")
  description        String?
  isActive           Boolean             @default(true)
  managerId          String?
  companyId          String?
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
  createdById        String?
  updatedById        String?
  WarehouseLocation  WarehouseLocation[]
  goodsReceiptNotes  GoodsReceiptNote[]
  stockLedgerEntries StockLedger[]
  inventoryItems     InventoryItem[]
  purchaseReturns    PurchaseReturn[]
  fromTransferRequests TransferRequest[] @relation("TransferRequest_fromWarehouse")
  toTransferRequests   TransferRequest[] @relation("TransferRequest_toWarehouse")
  
  // Sales Relations
  erpSalesOrders     ERPSalesOrder[]
  deliveryChallans   DeliveryChallan[]
  erpSalesInvoices   ERPSalesInvoice[]
  purchaseInvoices   PurchaseInvoice[]

  @@index([companyId])
  @@index([type])
}
