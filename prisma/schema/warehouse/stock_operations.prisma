model StockMovement {
  id             String   @id @default(uuid())
  movementNo     String   @unique
  itemId         String
  fromLocationId String? // Warehouse (null) or Outlet Location
  toLocationId   String? // Outlet Location or Warehouse (null)
  quantity       Decimal  @db.Decimal(15, 4)
  type           String // TRANSFER, INBOUND, OUTBOUND
  referenceType  String?
  referenceId    String?
  notes          String?
  movementDate   DateTime @default(now())
  createdById    String?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  @@index([itemId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([movementDate])
  @@index([referenceId])
  @@index([type])
}

model TransferRequest {
  id                    String                @id @default(uuid())
  requestNo             String                @unique
  fromWarehouseId       String? // Can be null for outlet-to-warehouse transfers
  fromLocationId        String? // Source outlet for return transfers
  toLocationId          String? // Destination outlet (null for warehouse)
  transferType          String                @default("WAREHOUSE_TO_OUTLET") // WAREHOUSE_TO_OUTLET, OUTLET_TO_WAREHOUSE, OUTLET_TO_OUTLET
  status                String                @default("PENDING") // PENDING, SOURCE_APPROVED, COMPLETED, REJECTED
  requestDate           DateTime              @default(now())
  expectedDate          DateTime?
  createdById           String?
  approvedById          String?
  
  // Dual approval fields for outlet-to-outlet transfers
  requiresSourceApproval Boolean              @default(false)
  sourceApprovedById     String?
  sourceApprovedAt       DateTime?
  
  notes                 String?
  createdAt             DateTime              @default(now())
  updatedAt             DateTime              @updatedAt
  items                 TransferRequestItem[]
  fromWarehouse         Warehouse?            @relation("TransferRequestFromWH", fields: [fromWarehouseId], references: [id])

  @@index([fromWarehouseId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([status])
  @@index([transferType])
}

model TransferRequestItem {
  id                String          @id @default(uuid())
  transferRequestId String
  itemId            String
  quantity          Decimal         @db.Decimal(15, 4)
  fulfilledQty      Decimal         @default(0) @db.Decimal(15, 4)
  transferRequest   TransferRequest @relation(fields: [transferRequestId], references: [id], onDelete: Cascade)
  item              Item            @relation(fields: [itemId], references: [id])

  @@unique([transferRequestId, itemId])
}
