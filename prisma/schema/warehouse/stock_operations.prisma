model StockMovement {
  id             String             @id @default(uuid())
  movementNo     String             @unique
  itemId         String
  fromLocationId String?
  toLocationId   String?
  quantity       Decimal            @db.Decimal(15, 4)
  batchNumber    String?
  serialNumber   String?
  expiryDate     DateTime?
  type           String
  referenceType  String?
  referenceId    String?
  reason         String?
  notes          String?
  movementDate   DateTime           @default(now())
  createdById    String?
  createdAt      DateTime           @default(now())
  updatedAt      DateTime           @updatedAt
  fromLocation   WarehouseLocation? @relation("MovementFrom", fields: [fromLocationId], references: [id])
  toLocation     WarehouseLocation? @relation("MovementTo", fields: [toLocationId], references: [id])

  @@index([itemId])
  @@index([fromLocationId])
  @@index([toLocationId])
  @@index([movementDate])
  @@index([referenceId])
  @@index([type])
}

model TransferRequest {
  id              String                @id @default(uuid())
  requestNo       String                @unique
  fromWarehouseId String
  toWarehouseId   String
  status          String                @default("DRAFT")
  requestDate     DateTime              @default(now())
  expectedDate    DateTime?
  createdById     String?
  approvedById    String?
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt
  items           TransferRequestItem[]
}

model TransferRequestItem {
  id                String          @id @default(uuid())
  transferRequestId String
  itemId            String
  quantity          Decimal         @db.Decimal(15, 4)
  batchNumber       String?
  fulfilledQty      Decimal         @default(0) @db.Decimal(15, 4)
  transferRequest   TransferRequest @relation(fields: [transferRequestId], references: [id], onDelete: Cascade)

  @@unique([transferRequestId, itemId, batchNumber])
}
