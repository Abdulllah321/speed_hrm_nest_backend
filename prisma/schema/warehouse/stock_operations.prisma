model StockMovement {
    id         String @id @default(uuid())
    movementNo String @unique // Auto-generated e.g. MV-20240210-001

    itemId String // Reference to Master DB Item.id

    // Source & Destination
    fromLocationId String?
    toLocationId   String?

    fromLocation WarehouseLocation? @relation("MovementFrom", fields: [fromLocationId], references: [id])
    toLocation   WarehouseLocation? @relation("MovementTo", fields: [toLocationId], references: [id])

    quantity Decimal @db.Decimal(15, 4)

    // Batch Info Snapshots
    batchNumber  String?
    serialNumber String?
    expiryDate   DateTime?

    type String // INBOUND, OUTBOUND, TRANSFER, ADJUSTMENT

    // Audit Reference
    referenceType String? // PO, SO, PRODUCTION, RETURN
    referenceId   String? // ID of the document

    reason String?
    notes  String?

    movementDate DateTime @default(now())
    createdById  String? // User who performed action

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt

    @@index([itemId])
    @@index([fromLocationId])
    @@index([toLocationId])
    @@index([movementDate])
    @@index([referenceId])
    @@index([type])
}

model TransferRequest {
    id        String @id @default(uuid())
    requestNo String @unique

    fromWarehouseId String
    toWarehouseId   String

    status String @default("DRAFT") // DRAFT, APPROVED, IN_TRANSIT, COMPLETED, CANCELLED

    requestDate  DateTime  @default(now())
    expectedDate DateTime?

    items TransferRequestItem[]

    createdById  String?
    approvedById String?

    createdAt DateTime @default(now())
    updatedAt DateTime @updatedAt
}

model TransferRequestItem {
    id                String  @id @default(uuid())
    transferRequestId String
    itemId            String
    quantity          Decimal @db.Decimal(15, 4)

    // Optional specific batch request
    batchNumber String?

    fulfilledQty Decimal @default(0) @db.Decimal(15, 4)

    transferRequest TransferRequest @relation(fields: [transferRequestId], references: [id], onDelete: Cascade)

    @@unique([transferRequestId, itemId, batchNumber])
}
