model InventoryItem {
  id          String    @id @default(uuid())
  warehouseId String
  locationId  String?   // Optional - for outlets only
  itemId      String
  quantity    Decimal   @default(0) @db.Decimal(15, 4)
  status      String    @default("AVAILABLE")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  warehouse   Warehouse @relation(fields: [warehouseId], references: [id])
  item        Item      @relation(fields: [itemId], references: [id])

  @@unique([warehouseId, locationId, itemId, status])
  @@index([itemId])
  @@index([warehouseId])
  @@index([locationId])
}

model StockReserve {
  id            String    @id @default(uuid())
  itemId        String
  warehouseId   String
  quantity      Decimal   @db.Decimal(15, 4)
  referenceType String
  referenceId   String
  notes         String?
  expiresAt     DateTime?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  createdById   String?

  @@index([itemId, warehouseId])
  @@index([referenceId])
}
